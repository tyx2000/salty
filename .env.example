# Supabase browser client.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Drizzle migrations. Use Supabase pooled Postgres connection string.
DATABASE_URL=

# Optional server/runtime aliases. If omitted locally, Vite falls back to VITE_*.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional provider base URLs.
# Use this when local network cannot directly reach api.openai.com, or when using
# an OpenAI-compatible gateway. OPENAI_BASE_URL should include /v1.
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional local development proxy for Node fetch in npm run dev.
# Example:
# HTTPS_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=
